{
  "name": "multiagent-coding-workflow-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "apps/daemon"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck -w @multiagent/shared && npm run typecheck -w @multiagent/daemon",
    "daemon": "npm run dev -w @multiagent/daemon",
    "mac:build": "swift build --package-path apps/mac",
    "mac:run": "./script/build_and_run.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
